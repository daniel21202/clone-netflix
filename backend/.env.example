# MySQL - ajuste usuario/senha/host conforme seu ambiente
DATABASE_URL="mysql://root:senha@localhost:3306/netflix_clone"

# Segredo usado para assinar os tokens JWT
JWT_SECRET="troque-por-um-segredo-forte"
JWT_EXPIRES_IN="7d"

# Chave da API do TMDB (https://www.themoviedb.org/settings/api)
TMDB_API_KEY="sua-chave-tmdb-aqui"
TMDB_BASE_URL="https://api.themoviedb.org/3"

PORT=3001
