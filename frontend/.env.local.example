# Chave da API do TMDB (usada pelo proxy em src/app/api/tmdb) - fica só no servidor, nunca exposta ao browser
TMDB_API_KEY="sua-chave-tmdb-aqui"

# Credenciais do projeto Supabase (Settings -> API no painel do Supabase)
# A anon key é pública por design (protegida pelas policies de RLS), pode ir com NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-anon-key-aqui"
